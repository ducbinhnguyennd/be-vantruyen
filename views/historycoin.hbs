<!DOCTYPE html>
<html>

<head>
    <title>Comic</title>
    <link href='https://unpkg.com/boxicons@2.0.9/css/boxicons.min.css' rel='stylesheet'>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.3/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
    <script src="https://code.jquery.com/jquery-3.3.1.slim.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.7/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js"></script>
</head>


<body>
    <div class="jumbotron text-center">
        <h1>
            {{#if isAdmin}}
            Withdraw Coin
            {{else}}
            History Coin
            {{/if}}
        </h1>
        <hr>
        <div class="table-data">
            <div class="order">
                <table class="table">
                    <thead class="thead-dark">
                        <tr>
                            <th style="text-align: center;">Ngày</th>
                            <th style="text-align: center;">Nội dung</th>
                            <th style="text-align: center;">Phương thức</th>
                            <th style="text-align: center;">
                                Coin
                            </th>
                            {{#if isAdmin}}

                            <th style="text-align: center;">Quy đổi</th>
                            <th style="text-align: center;">User</th>
                            <th style="text-align: center;">Ngân hàng</th>
                            <th style="text-align: center;">Số tài khoản</th>
                            <th style="text-align: center;">Option</th>
                            {{/if}}
                        </tr>
                    </thead>

                    <tbody>
                        {{#each historyjson}}
                        <tr>
                            <td style="text-align: center;">{{this.date}}</td>
                            <td style="text-align: center;">{{this.content}}</td>
                            <td style="text-align: center;">{{this.method}}</td>
                            <td style="text-align: center;">{{formatNumber this.coin}}</td>
                            {{#if ../isAdmin}}
                            <td style="text-align: center;">{{formatNumber this.quydoi}}</td>
                            <td style="text-align: center;">{{this.user}}</td>
                            <td style="text-align: center;">
                                {{this.nganhang}}
                            </td>
                            <td style="text-align: center;">
                                {{this.stk}}
                            </td>

                            <td>
                                <form style="margin-top: 10px;" action="/duyetrutien/{{this._id}}"
                                    onclick="return confirm('Bạn có muốn duyệt lệnh rút tiền?')" method="post">
                                    <button
                                        style="width: 100px; height: 30px; margin-top: 5px; background-color: #1E90FF; border: none; border-radius: 5px; color: white;"
                                        type="submit">Duyệt</button>
                                </form>
                                <form style="margin-top: 10px;" action="/huyrutien/{{this._id}}"
                                    onclick="return confirm('Bạn có muốn hủy lệnh rút tiền?')" method="post">
                                    <button
                                        style="width: 100px; height: 30px; margin-top: 5px; background-color: #f50d0d; border: none; border-radius: 5px; color: white;"
                                        type="submit">Hủy</button>
                                </form>
                            </td>
                            {{/if}}
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>



    </script>
</body>

</html>